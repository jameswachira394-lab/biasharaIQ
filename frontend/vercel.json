{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "regions": [
    "fra1"
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "https://biasharaiq.onrender.com",
    "NEXT_PUBLIC_APP_NAME": "BiasharaIQ",
    "NODE_ENV": "production"
  },
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "functions": {
    "api/**": {
      "memory": 512,
      "maxDuration": 30
    }
  }
}
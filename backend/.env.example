# Backend Environment Configuration
# Copy this file to .env and update with your actual values

# ====================
# Environment
# ====================
ENVIRONMENT=development
# For production, set to: production

# ====================
# Database Configuration
# ====================
DATABASE_URL=postgresql://biasharaiq:biasharaiq_pass@localhost/biasharaiq
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ====================
# Security Keys
# ====================
# Generate with: openssl rand -hex 32 (on Linux/Mac) or use Python: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production-min-32-chars
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars

# ====================
# API Keys
# ====================
ANTHROPIC_API_KEY=sk-ant-your-key-here
GEMINI_API_KEY=your-gemini-key-here

# ====================
# CORS Configuration
# ====================
# For development: Allow localhost
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ====================
# Logging
# ====================
LOG_LEVEL=DEBUG
# For production, use: INFO, WARNING, ERROR

# ====================
# Port Configuration
# ====================
PORT=8000

# ====================
# Optional: Sentry (Error Tracking)
# ====================
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
